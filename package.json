{
  "name": "daimon-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Low-latency I/O relay between body and agent",
  "license": "ISC",
  "type": "commonjs",
  "main": "dist/main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --watch src src/main.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "drizzle-orm": "^0.45.2",
    "nestjs-zod": "^5.4.0",
    "postgres": "^3.4.9",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "^1.15.40",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.7"
  }
}
